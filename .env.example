# Phase 2 contains secret paths only. Do not put real secrets in this file.

MERCURY_APP_NAME=Mercury Wallet Agent
MERCURY_DEFAULT_CHAIN=ethereum

# These values are 1Claw secret paths, not live RPC URLs.
MERCURY_ETHEREUM_RPC_SECRET_PATH=mercury/rpc/ethereum
MERCURY_BASE_RPC_SECRET_PATH=mercury/rpc/base

# 1Claw connection metadata. The agent API key should live in the secret source env var.
# Hosted api.1claw.xyz: set MERCURY_ONECLAW_BASE_URL=https://api.1claw.xyz ,
# MERCURY_ONECLAW_VAULT_ID=<vault UUID>, MERCURY_ONECLAW_AGENT_ID=<agent id>.
# With MERCURY_ONECLAW_AGENT_ID set, Mercury exchanges MERCURY_ONECLAW_API_KEY for a JWT
# then GETs /v1/vaults/{vault}/secrets/{path}. Without agent id, legacy POST secrets:resolve is used.
MERCURY_ONECLAW_BASE_URL=http://localhost:8080
MERCURY_ONECLAW_VAULT_ID=mercury
MERCURY_ONECLAW_API_KEY_SECRET_SOURCE=MERCURY_ONECLAW_API_KEY
MERCURY_ONECLAW_AGENT_ID=
